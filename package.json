{
  "name": "alttext-ai-api",
  "version": "1.0.0",
  "description": "Proxy API for AltText AI WordPress plugin",
  "main": "fresh-stack/server.js",
  "scripts": {
    "start": "node fresh-stack/server.js",
    "start:fresh": "node fresh-stack/server.js",
    "dev": "nodemon fresh-stack/server.js",
    "test": "jest --runInBand --forceExit",
    "test:unit": "jest tests/unit --runInBand --forceExit",
    "test:integration": "jest tests/integration --runInBand --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --runInBand --coverage --ci",
    "smoke": "bash fresh-stack/tests/smoke.sh",
    "diagnostics:data-integrity": "node fresh-stack/scripts/print-data-integrity-diagnostics.js",
    "ledger:sync": "node fresh-stack/scripts/sync-image-alt-states.js",
    "verify:site-quota-v2": "node fresh-stack/scripts/verify-site-quota-v2-schema.js --pretty",
    "repair:stripe-entitlement": "node scripts/repair-stripe-subscription-entitlement.js"
  },
  "keywords": [
    "alttext",
    "api",
    "openai",
    "wordpress"
  ],
  "author": "AltText AI",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.84.0",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.0.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dayjs": "^1.11.13",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "pdfkit": "^0.15.0",
    "pg": "^8.16.3",
    "resend": "^6.8.0",
    "stripe": "^20.0.0",
    "ws": "^8.18.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
